				{
					"name": "7. GET - Tips Report (Valid Date Range)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"",
									"pm.test('Response contains tips report data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.report).to.have.property('userId');",
									"    pm.expect(jsonData.report).to.have.property('firstName');",
									"    pm.expect(jsonData.report).to.have.property('lastName');",
									"    pm.expect(jsonData.report).to.have.property('period');",
									"    pm.expect(jsonData.report).to.have.property('summary');",
									"    pm.expect(jsonData.report).to.have.property('data');",
									"});",
									"",
									"pm.test('Summary contains expected fields', function () {",
									"    const jsonData = pm.response.json();",
									"    const summary = jsonData.report.summary;",
									"    pm.expect(summary).to.have.property('totalTips');",
									"    pm.expect(summary).to.have.property('totalShifts');",
									"    pm.expect(summary.totalTips).to.be.a('number');",
									"    pm.expect(summary.totalShifts).to.be.a('number');",
									"});",
									"",
									"pm.test('Tips data contains shift details', function () {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.report.data.length > 0) {",
									"        const shift = jsonData.report.data[0];",
									"        pm.expect(shift).to.have.property('shiftId');",
									"        pm.expect(shift).to.have.property('date');",
									"        pm.expect(shift).to.have.property('coreBlock');",
									"        pm.expect(shift.coreBlock).to.have.property('timeStart');",
									"        pm.expect(shift.coreBlock).to.have.property('timeEnd');",
									"    }",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
