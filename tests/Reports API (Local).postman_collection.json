			"name": "Hours Reports Tests",
			"item": [
				{
					"name": "13. GET - Hours Report (Valid Date Range)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"",
									"pm.test('Response contains hours report data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.report).to.have.property('userId');",
									"    pm.expect(jsonData.report).to.have.property('firstName');",
									"    pm.expect(jsonData.report).to.have.property('lastName');",
									"    pm.expect(jsonData.report).to.have.property('period');",
									"    pm.expect(jsonData.report).to.have.property('summary');",
									"    pm.expect(jsonData.report).to.have.property('data');",
									"});",
									"",
									"pm.test('Summary contains expected fields', function () {",
									"    const jsonData = pm.response.json();",
									"    const summary = jsonData.report.summary;",
									"    pm.expect(summary).to.have.property('totalHours');",
									"    pm.expect(summary).to.have.property('totalShifts');",
									"    pm.expect(summary.totalHours).to.be.a('number');",
									"    pm.expect(summary.totalShifts).to.be.a('number');",
									"});",
									"",
									"pm.test('Hours calculation is correct for core block times', function () {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.report.data.length > 0) {",
									"        const shift = jsonData.report.data[0];",
									"        pm.expect(shift).to.have.property('hoursWorked');",
									"        pm.expect(shift.hoursWorked).to.be.a('number');",
									"        // Core block is 930-1330 which should be 4.0 hours (9:30 to 13:30)",
									"        pm.expect(shift.hoursWorked).to.equal(4.0);",
									"        pm.expect(shift.coreBlock.timeStart).to.equal(930);",
									"        pm.expect(shift.coreBlock.timeEnd).to.equal(1330);",
									"    }",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
