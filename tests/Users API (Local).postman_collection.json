			"item": [
				{
					"name": "1. POST - Create User (Valid)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.success).to.eql(true);",
									"});",
									"",
									"pm.test('Response contains user data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.users).to.have.property('id');",
									"    pm.expect(jsonData.users.firstName).to.eql('John');",
									"    pm.expect(jsonData.users.lastName).to.eql('Doe');",
									"    pm.expect(jsonData.users.email).to.eql('john.doe@example.com');",
									"});",
									"",
									"pm.test('User has default values', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.users.role).to.eql('unvalidated');",
									"    pm.expect(jsonData.users.status).to.eql('active');",
									"});",
									"",
									"// Save user ID for other tests",
									"if (pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    pm.collectionVariables.set('userId', jsonData.users.id);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
