				{
					"name": "1. POST - Create Core Block (Valid)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has success true', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.success, true);",
									"});",
									"",
									"pm.test('Response contains core block data', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.coreBlocks).to.have.property('id');",
									"    pm.expect(jsonData.coreBlocks.dayOfWeek, 'mon');",
									"    pm.expect(jsonData.coreBlocks.shiftOfDay, 'm1');",
									"});",
									"",
									"// Save core block ID for other tests",
									"if (pm.response.code === 201) {",
									"    const jsonData = pm.response.json();",
									"    pm.collectionVariables.set('coreBlockId', jsonData.coreBlocks.id);",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": 1,\n  \"dayOfWeek\": \"mon\",\n  \"shiftOfDay\": \"m1\",\n  \"timeStart\": 800,\n  \"timeEnd\": 1200,\n  \"numberOfEmployees\": 2\n}"
